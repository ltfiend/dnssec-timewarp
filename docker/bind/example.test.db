$TTL 3600
@   IN SOA  ns1.example.test. hostmaster.example.test. (
            2026010101 ; serial
            3600       ; refresh
            900        ; retry
            1209600    ; expire
            3600 )     ; negative TTL
    IN NS   ns1.example.test.
ns1 IN A    127.0.0.1
www IN A    192.0.2.1
